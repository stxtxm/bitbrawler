# Configuration pour Supabase
# Copiez ce fichier en .env et remplissez avec vos valeurs

# URL de votre projet Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co

# Clé anonyme pour le client (disponible dans Settings > API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im...

# Token d'accès à l'API de gestion Supabase (généré depuis Settings > API)
# Nécessaire pour exécuter les migrations automatiquement
# SUPABASE_ACCESS_TOKEN=sbap_abc123...

# Variables pour les scripts (à configurer dans GitHub Secrets)
# SUPABASE_URL=https://votre-projet.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im...
